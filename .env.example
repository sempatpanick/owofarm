# USER account token only — NOT a bot token from https://discord.com/developers/applications
# Multiple accounts: separate with commas, e.g. "TOKEN1,TOKEN2"
TOKEN="YOUR_USER_ACCOUNT_TOKEN_HERE"

# Optional: automatic OwO captcha solving (capsolver, capmonster, or 2captcha)
# Browser opens immediately on captcha; auto-solver runs in parallel as a bonus attempt.
# CAPTCHA_API_KEY="your_solver_api_key"
# CAPTCHA_SERVICE="capsolver"
# CAPTCHA_SOLVE_TIMEOUT=90

# Isolated browser: each account opens its captcha in its OWN Chrome instance
# (separate --user-data-dir per account), so multiple accounts no longer share
# cookies/session when solving captchas at the same time. The captcha-solver
# extension is still loaded into every profile via --load-extension.
# BROWSER_ISOLATED=true                       # default true; set false to use the system default browser
#                                             # when false, captcha browser opens are queued: only one account
#                                             # at a time until OwO sends the verification success message
# BROWSER_PROFILES_DIR="./browser-profiles"   # where per-account Chrome profiles are stored
# BROWSER_EXECUTABLE="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"  # auto-detected if omitted
# BROWSER_EXTENSION_ID="dknlfmjaanfblgfdfebhijalfmhmjjjo"   # used to find ./browser-profiles/.extension-cache/<id>
# BROWSER_EXTENSION_PATH="/path/to/unpacked/extension"      # optional explicit path (must contain manifest.json)